{
  "installCommand": "echo skip-install",
  "buildCommand": "echo skip-build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.wirex.online:8443/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
